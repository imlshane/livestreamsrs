APP_NAME=Zinrai Livestream API
DEBUG=false
DOMAIN=livestream.zinrai.live

# PostgreSQL (Managed DO)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/videomanager

# Redis (Managed DO)
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
REDIS_PREFIX=livestream:

# DigitalOcean Spaces
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_BUCKET=zinrai-live-stream-cdn
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://zinrai-live-stream-cdn.nyc3.digitaloceanspaces.com

# SRS
SRS_PUBLISH_SECRET=change-me-random-secret
SRS_API_URL=http://srs:1985

# JWT
JWT_SECRET_KEY=change-me-64-char-hex
JWT_EXPIRY_MINUTES=480

# Paths (inside containers)
DVR_PATH=/dvr
HLS_PATH=/hls-data

# Stream limits
STREAM_MAX_DURATION_SECONDS=7200
MAX_CONCURRENT_STREAMS=5

# CORS
ALLOWED_ORIGINS=https://zinrai.live,https://www.zinrai.live
